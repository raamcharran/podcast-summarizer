{
  "name": "podcast-summarizer",
  "version": "0.1.0",
  "description": "Turn any podcast episode into an interactive visual summary — AI-generated infographics, knowledge graph, speaker attribution, and chapter breakdowns. Works with Anthropic, OpenAI, or local Claude CLI.",
  "main": "index.js",
  "type": "module",
  "keywords": [
    "podcast",
    "ai",
    "summary",
    "infographic",
    "knowledge-graph",
    "transcript",
    "anthropic",
    "openai",
    "claude"
  ],
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/*.test.js",
    "test:evals": "node --test test/evals/*.eval.test.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "p-limit": "^6.1.0",
    "youtube-transcript": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
